# ─── Sunucu ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3001

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Admin (seed script bu değerleri kullanır) ─────────────────
ADMIN_EMAIL=admin@atala.com
ADMIN_PASSWORD=ChangeMe_Admin123!
ADMIN_NAME=Atala Admin

# ─── Auth güvenlik ─────────────────────────────────────────────
# Production'da public kayıt kapalı; açmak için: ENABLE_PUBLIC_REGISTER=true
ENABLE_PUBLIC_REGISTER=false
LOGIN_LOG_RETENTION_DAYS=30
PASSWORD_RESET_EXPIRES_MINUTES=60
# Production: 10 IP / 5 e-posta denemesi. Development'ta varsayılan daha yüksektir (100).
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_EMAIL_MAX_ATTEMPTS=5

# ─── SMTP (şifre sıfırlama e-postası — boşsa dev modda konsola yazılır)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@atala.com

# ─── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL="postgresql://root:secretpassword@localhost:5433/ecommerce_db?schema=public"
