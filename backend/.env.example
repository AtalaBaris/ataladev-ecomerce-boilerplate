# ─── Sunucu ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT (üretimde güçlü, rastgele bir değer kullanın) ───────
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# ─── PostgreSQL (docker-compose.yml ile uyumlu) ──────────────
# Yerel PostgreSQL 5432'de çalışıyorsa port 5433 kullanın
DATABASE_URL="postgresql://root:secretpassword@localhost:5433/ecommerce_db?schema=public"
